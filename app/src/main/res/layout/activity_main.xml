<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- אייקוני כלים עליונים -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/btn_star_big_off"
            android:tint="#FFFFFF"/>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnFlip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="#FFFFFF"/>

    </LinearLayout>

    <!-- כפתורי זום -->
    <LinearLayout
        android:id="@+id/zoomBar"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#99000000"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/modesBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <TextView android:id="@+id/zoomPt6"
            android:layout_width="52dp" android:layout_height="40dp"
            android:text=".6" android:textColor="#AAAAAA" android:textSize="15sp"
            android:gravity="center"/>
        <TextView android:id="@+id/zoom1x"
            android:layout_width="52dp" android:layout_height="40dp"
            android:text="1×" android:textColor="#FFFFFF" android:textSize="15sp"
            android:textStyle="bold" android:gravity="center"
            android:background="#44FFFFFF"/>
        <TextView android:id="@+id/zoom2x"
            android:layout_width="52dp" android:layout_height="40dp"
            android:text="2" android:textColor="#AAAAAA" android:textSize="15sp"
            android:gravity="center"/>
        <TextView android:id="@+id/zoom3x"
            android:layout_width="52dp" android:layout_height="40dp"
            android:text="3" android:textColor="#AAAAAA" android:textSize="15sp"
            android:gravity="center"/>
        <TextView android:id="@+id/zoom10x"
            android:layout_width="52dp" android:layout_height="40dp"
            android:text="10" android:textColor="#AAAAAA" android:textSize="15sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- בר מצבים -->
    <LinearLayout
        android:id="@+id/modesBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <TextView android:id="@+id/modeFocus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="דיוק" android:textColor="#AAAAAA" android:textSize="15sp"
            android:paddingHorizontal="20dp"/>
        <TextView android:id="@+id/modePhoto"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="תמונה" android:textColor="#FFFFFF" android:textSize="16sp"
            android:textStyle="bold" android:paddingHorizontal="20dp"/>
        <TextView android:id="@+id/modeVideo"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="וידאו" android:textColor="#AAAAAA" android:textSize="15sp"
            android:paddingHorizontal="20dp"/>
        <TextView android:id="@+id/modeMore"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="עוד" android:textColor="#AAAAAA" android:textSize="15sp"
            android:paddingHorizontal="20dp"/>

    </LinearLayout>

    <!-- בר תחתון -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="32dp"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- גלריה -->
        <ImageButton
            android:id="@+id/btnGallery"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="#44FFFFFF"
            android:src="@android:drawable/ic_menu_gallery"/>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- כפתור צילום עגול -->
        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@android:color/white"
            android:src="@android:drawable/ic_menu_camera"/>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- הפיכת מצלמה -->
        <ImageButton
            android:id="@+id/btnVideo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="#44FFFFFF"
            android:src="@android:drawable/ic_media_play"/>

    </LinearLayout>

    <!-- SeekBar זום מוסתר -->
    <SeekBar
        android:id="@+id/zoomSeekBar"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
