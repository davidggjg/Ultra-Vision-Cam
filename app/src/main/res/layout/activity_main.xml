<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <com.example.crazycamera.FaceOverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- כלים עליונים -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_gray"
            android:src="@android:drawable/ic_menu_camera"
            android:padding="10dp"/>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_gray"
            android:src="@android:drawable/ic_menu_preferences"
            android:padding="10dp"/>

    </LinearLayout>

    <!-- כפתורי זום -->
    <LinearLayout
        android:id="@+id/zoomBar"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#99000000"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/modesBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/zoomPt6"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:text=".6"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/zoom1x"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:text="1×"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#44FFFFFF"/>

        <TextView
            android:id="@+id/zoom2x"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:text="2"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/zoom3x"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:text="3"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/zoom10x"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:text="10"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- בר מצבים -->
    <LinearLayout
        android:id="@+id/modesBar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <TextView
            android:id="@+id/modeFocus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="דיוק"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:paddingHorizontal="16dp"/>

        <TextView
            android:id="@+id/modePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="תמונה"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"/>

        <TextView
            android:id="@+id/modeVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="וידאו"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:paddingHorizontal="16dp"/>

        <TextView
            android:id="@+id/modeMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="עוד"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:paddingHorizontal="16dp"/>

    </LinearLayout>

    <!-- בר תחתון -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="32dp"
        android:background="#DD000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnGallery"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/circle_gray"
            android:src="@android:drawable/ic_menu_gallery"
            android:padding="12dp"/>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <FrameLayout
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:gravity="center">

            <View
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:background="@drawable/circle_outline"
                android:layout_gravity="center"/>

            <ImageButton
                android:id="@+id/btnCapture"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/circle_white"
                android:src="@null"
                android:layout_gravity="center"/>

        </FrameLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnFlip"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/circle_gray"
            android:src="@android:drawable/ic_menu_rotate"
            android:padding="12dp"/>

    </LinearLayout>

    <SeekBar
        android:id="@+id/zoomSeekBar"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
